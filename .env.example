# PolicyLens AI — Environment Variables
# Copy this file to .env and fill in your values

# Database (leave blank to use SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./policylens.db
# For PostgreSQL production:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/policylens

# Ollama (local LLM — runs on your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Translation
LIBRETRANSLATE_URL=http://localhost:5000

# Groq Free API (optional — ultra-fast fallback, free at console.groq.com)
GROQ_API_KEY=

# MinIO (optional — S3-compatible local storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=policylens-docs
